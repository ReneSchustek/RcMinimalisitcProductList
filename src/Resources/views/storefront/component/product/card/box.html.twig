{% sw_extends '@Storefront/storefront/component/product/card/box.html.twig' %}

{% block component_product_box_include %}
    {# Minimalistic-Layout: Extension vom ListingLayoutSubscriber (AJAX-sicher) #}
    {% if searchResult is defined
        and searchResult.extensions.rcMinimalisticLayout is defined
        and searchResult.extensions.rcMinimalisticLayout.active %}
        {% set layout = 'minimalistic' %}
    {# Fallback: direkter Navigationszugriff fuer nicht-Listing-Kontexte #}
    {% elseif page.header.navigation.active.customFields.rc_show_minimalistic_productlist ?? false %}
        {% set layout = 'minimalistic' %}
    {% endif %}

    {{ parent() }}
{% endblock %}
